<?xml version="1.0" encoding="utf-8"?>
<!--
  Network Security Config for Universal Marine Radar Display.

  Cleartext HTTP/WS is required for:
    - 127.0.0.1  — embedded server on physical device (JNI server binds here)
    - 10.0.2.2   — Android emulator host loopback alias
    - LAN radar hardware — marine radar devices do not support TLS

  The base-config permits cleartext globally because network-mode connects to
  radar hardware on the local network which does not support HTTPS/WSS.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>
